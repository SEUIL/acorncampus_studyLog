<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- 필터: 등록(<filter>) 후 URL 연결(<filter-mapping>) -->

    <!-- UTF-8 인코딩: 모든 요청 적용 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.acorncampus_studylog.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 잔디(기여도 그래프) 데이터 주입: 모든 요청에 적용
         - 로그인 유저에게만 DB 조회 수행 (비로그인/정적 리소스는 필터 내부에서 즉시 통과)
         - EncodingFilter 다음, LoginCheckFilter 전에 위치해야 함 -->
    <filter>
        <filter-name>JandiFilter</filter-name>
        <filter-class>com.acorncampus_studylog.filter.JandiFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>JandiFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 로그인/권한 체크: /l_check/* (로그인 필수) + /admin/* (ADMIN 역할 필수) -->
    <filter>
        <filter-name>LoginCheckFilter</filter-name>
        <filter-class>com.acorncampus_studylog.filter.LoginCheckFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginCheckFilter</filter-name>
        <url-pattern>/l_check/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>LoginCheckFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- 세션 유지 시간: 30분 -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- 정적 리소스: DefaultServlet에 위임 (MainController @WebServlet("/") 충돌 방지) -->
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/resources/*</url-pattern>
    </servlet-mapping>

    <!-- 루트 URL 접속 시 첫 페이지 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
